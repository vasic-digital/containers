# Test Configuration: Remote Deployment (Single Host)
# This configuration tests containers running on a single remote host

# Remote distribution enabled - all containers run on remote host
CONTAINERS_REMOTE_ENABLED=true

# Scheduler strategy: resource_aware, round_robin, affinity, spread, bin_pack
CONTAINERS_REMOTE_SCHEDULER=resource_aware

# Single remote host configuration
CONTAINERS_REMOTE_HOST_1_NAME=thinker
CONTAINERS_REMOTE_HOST_1_ADDRESS=thinker.local
CONTAINERS_REMOTE_HOST_1_PORT=22
CONTAINERS_REMOTE_HOST_1_USER=milosvasic
CONTAINERS_REMOTE_HOST_1_RUNTIME=podman
CONTAINERS_REMOTE_HOST_1_LABELS=storage=fast,memory=high

# SSH connection settings
CONTAINERS_REMOTE_CONNECT_TIMEOUT=10
CONTAINERS_REMOTE_COMMAND_TIMEOUT=60
CONTAINERS_REMOTE_CONTROL_MASTER=true
CONTAINERS_REMOTE_CONTROL_PERSIST=600
CONTAINERS_REMOTE_MAX_CONNECTIONS=5

# Port range for SSH tunnels
CONTAINERS_REMOTE_PORT_RANGE_START=20000
CONTAINERS_REMOTE_PORT_RANGE_END=30000
