# Test Configuration: Remote Deployment (Multi-Host Cluster)
# This configuration tests containers distributed across multiple remote hosts

# Remote distribution enabled - containers distributed across hosts
CONTAINERS_REMOTE_ENABLED=true

# Scheduler strategy: resource_aware for optimal distribution
CONTAINERS_REMOTE_SCHEDULER=resource_aware

# Host 1: Primary compute node
CONTAINERS_REMOTE_HOST_1_NAME=thinker
CONTAINERS_REMOTE_HOST_1_ADDRESS=thinker.local
CONTAINERS_REMOTE_HOST_1_PORT=22
CONTAINERS_REMOTE_HOST_1_USER=milosvasic
CONTAINERS_REMOTE_HOST_1_RUNTIME=podman
CONTAINERS_REMOTE_HOST_1_LABELS=storage=fast,memory=high,compute=cpu

# Host 2: GPU node (placeholder - replace with actual GPU host)
CONTAINERS_REMOTE_HOST_2_NAME=gpu-server
CONTAINERS_REMOTE_HOST_2_ADDRESS=gpu-server.local
CONTAINERS_REMOTE_HOST_2_PORT=22
CONTAINERS_REMOTE_HOST_2_USER=deploy
CONTAINERS_REMOTE_HOST_2_RUNTIME=docker
CONTAINERS_REMOTE_HOST_2_LABELS=gpu=true,memory=high,compute=gpu

# Host 3: Storage node (placeholder)
CONTAINERS_REMOTE_HOST_3_NAME=storage-node
CONTAINERS_REMOTE_HOST_3_ADDRESS=storage-node.local
CONTAINERS_REMOTE_HOST_3_PORT=22
CONTAINERS_REMOTE_HOST_3_USER=deploy
CONTAINERS_REMOTE_HOST_3_RUNTIME=podman
CONTAINERS_REMOTE_HOST_3_LABELS=storage=large,memory=low,compute=none

# SSH connection settings
CONTAINERS_REMOTE_CONNECT_TIMEOUT=10
CONTAINERS_REMOTE_COMMAND_TIMEOUT=120
CONTAINERS_REMOTE_CONTROL_MASTER=true
CONTAINERS_REMOTE_CONTROL_PERSIST=600
CONTAINERS_REMOTE_MAX_CONNECTIONS=10

# Port range for SSH tunnels
CONTAINERS_REMOTE_PORT_RANGE_START=20000
CONTAINERS_REMOTE_PORT_RANGE_END=30000
