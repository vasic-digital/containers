# Containerfile for the §6.X (Container-Submodule Emulator Wiring
# Mandate) Android emulator image. This file is the deliverable
# referenced by parent Lava CLAUDE.md §6.X-debt close criterion (3):
# "bake or fetch an Android-SDK-bearing container image".
#
# Buildable on: Linux x86_64 with /dev/kvm available.
# NOT buildable / runnable on: darwin/arm64 (no /dev/kvm).
# Recorded in: .lava-ci-evidence/sixth-law-incidents/2026-05-13-emulator-container-darwin-arm64-gap.json
#
# Build command (Linux x86_64):
#   podman build --build-arg API_LEVEL=34 --build-arg ABI=x86_64 \
#       -f pkg/emulator/Containerfile \
#       -t ghcr.io/vasic-digital/lava-android-emulator:api34-x86_64 .
#
# Run command (entrypoint reads env vars set by Containerized.Boot):
#   podman run -d --rm --device /dev/kvm \
#       -p 5555:5555/tcp -p 5554:5554/tcp \
#       -e ANDROID_AVD_NAME=Pixel_API34_Phone \
#       -e ANDROID_COLD_BOOT=true \
#       ghcr.io/vasic-digital/lava-android-emulator:api34-x86_64

ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

# Image identity — recorded in attestation rows per §6.X clause 6.
LABEL org.opencontainers.image.title="lava-android-emulator"
LABEL org.opencontainers.image.description="Headless Android emulator for §6.X gate runs (Lava + Containers)"
LABEL org.opencontainers.image.source="https://github.com/vasic-digital/Containers"
LABEL org.opencontainers.image.licenses="See parent project LICENSE"
LABEL digital.vasic.containers.clause="6.X"

# Build args parameterise the AVD target. Override per-API/per-ABI image
# in the build pipeline; the runtime image baked here is opaque to the
# caller — Containerized.Boot just runs it with env vars set.
ARG API_LEVEL=34
ARG ABI=x86_64
ARG TARGET_TYPE=google_apis
ARG CMDLINE_TOOLS_VERSION=11076708
ARG SYSTEM_IMAGE_PACKAGE="system-images;android-${API_LEVEL};${TARGET_TYPE};${ABI}"

# Core deps. Per parent §6.U (No sudo/su Mandate), the image runs as a
# non-root user; apt installs run at build time with the implicit root
# of `docker build` / `podman build` — that is NOT a sudo invocation
# per §6.U (the user inside the running container is unprivileged).
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        unzip \
        openjdk-17-jdk-headless \
        libpulse0 \
        libnss3 \
        libxcomposite1 \
        libxcursor1 \
        libxi6 \
        libxtst6 \
        libasound2t64 \
        qemu-kvm \
        qemu-system-x86 \
        && rm -rf /var/lib/apt/lists/*

# Non-root user for the emulator runtime — clause 6.U inheritance.
RUN useradd -m -u 1000 -s /bin/bash emulator
USER emulator
WORKDIR /home/emulator

# Android SDK command-line tools — fetched from Google's canonical
# mirror. The build-arg version is the Google-published bundle id;
# update at image-rebuild time, never at runtime.
ENV ANDROID_SDK_ROOT=/home/emulator/android-sdk
RUN mkdir -p "${ANDROID_SDK_ROOT}/cmdline-tools" && \
    curl -fsSL "https://dl.google.com/android/repository/commandlinetools-linux-${CMDLINE_TOOLS_VERSION}_latest.zip" \
        -o /tmp/cmdline-tools.zip && \
    unzip -q /tmp/cmdline-tools.zip -d "${ANDROID_SDK_ROOT}/cmdline-tools" && \
    mv "${ANDROID_SDK_ROOT}/cmdline-tools/cmdline-tools" "${ANDROID_SDK_ROOT}/cmdline-tools/latest" && \
    rm /tmp/cmdline-tools.zip

ENV PATH="${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/platform-tools:${ANDROID_SDK_ROOT}/emulator:${PATH}"

# Accept SDK licenses, install platform-tools + emulator + the
# requested system image. The licenses are accepted at IMAGE-BUILD
# time, not at runtime — auditors reviewing the running container
# see no interactive license prompts.
RUN yes | sdkmanager --licenses > /dev/null 2>&1 || true && \
    sdkmanager --install \
        "platform-tools" \
        "emulator" \
        "${SYSTEM_IMAGE_PACKAGE}" \
        "platforms;android-${API_LEVEL}"

# Pre-create a default AVD matching the build-arg target. Production
# Containerized.Boot passes the AVD name via $ANDROID_AVD_NAME; the
# image's default AVD is the fallback for ad-hoc runs.
RUN echo "no" | avdmanager create avd \
        --name "default" \
        --package "${SYSTEM_IMAGE_PACKAGE}" \
        --device "pixel" || true

# Expose emulator console + adb ports. Containerized.Boot maps these
# to host ephemeral ports per §6.X clause 3 (--p <host>:5554, <host>:5555).
EXPOSE 5554/tcp 5555/tcp

# Entrypoint. Reads ANDROID_AVD_NAME + ANDROID_COLD_BOOT and invokes
# the emulator headlessly. The emulator process IS PID 1 of the
# container — when it exits, the container exits (§6.B-aware:
# container "Up" actually reflects emulator running).
COPY --chown=emulator:emulator pkg/emulator/entrypoint.sh /home/emulator/entrypoint.sh
RUN chmod +x /home/emulator/entrypoint.sh

ENTRYPOINT ["/home/emulator/entrypoint.sh"]
