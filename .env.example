# =============================================================
# Containers Module — Remote Distribution Configuration
# =============================================================
# Copy this file to .env and modify the values below.
# All CONTAINERS_REMOTE_* variables are optional. If not set,
# distribution operates in local-only mode.
# =============================================================

# --- Global Settings ---

# Enable remote container distribution.
CONTAINERS_REMOTE_ENABLED=false

# Default SSH user for all remote hosts (can be overridden per
# host).
CONTAINERS_REMOTE_DEFAULT_SSH_USER=deploy

# Default SSH private key path.
CONTAINERS_REMOTE_DEFAULT_SSH_KEY=~/.ssh/id_rsa

# Default container runtime on remote hosts (docker or podman).
CONTAINERS_REMOTE_DEFAULT_RUNTIME=docker

# Scheduling strategy: resource_aware, round_robin, affinity,
# spread, or bin_pack.
CONTAINERS_REMOTE_SCHEDULER=resource_aware

# --- Port Allocation for SSH Tunnels ---

# Local port range for SSH tunnel forwarding.
CONTAINERS_REMOTE_PORT_RANGE_START=20000
CONTAINERS_REMOTE_PORT_RANGE_END=30000

# --- Volume Settings ---

# Default volume mount type: sshfs, nfs, or rsync.
CONTAINERS_REMOTE_VOLUME_TYPE=sshfs

# --- SSH Connection Pool ---

# Enable SSH ControlMaster connection pooling.
CONTAINERS_REMOTE_SSH_CONTROL_MASTER=true

# ControlPersist duration (how long idle connections stay open).
CONTAINERS_REMOTE_SSH_CONTROL_PERSIST=300

# Maximum concurrent SSH connections per host.
CONTAINERS_REMOTE_SSH_MAX_CONNECTIONS=10

# --- Timeouts ---

# SSH connect timeout in seconds.
CONTAINERS_REMOTE_CONNECT_TIMEOUT=10

# Remote command execution timeout in seconds.
CONTAINERS_REMOTE_COMMAND_TIMEOUT=60

# --- Remote Host Definitions ---
# Define hosts using numbered entries: HOST_1, HOST_2, etc.
# Required fields per host: NAME and ADDRESS.
# Optional: PORT, USER, KEY, RUNTIME, LABELS.

# Host 1 example (GPU server):
# CONTAINERS_REMOTE_HOST_1_NAME=gpu-server-1
# CONTAINERS_REMOTE_HOST_1_ADDRESS=192.168.1.100
# CONTAINERS_REMOTE_HOST_1_PORT=22
# CONTAINERS_REMOTE_HOST_1_USER=deploy
# CONTAINERS_REMOTE_HOST_1_KEY=~/.ssh/gpu_key
# CONTAINERS_REMOTE_HOST_1_RUNTIME=docker
# CONTAINERS_REMOTE_HOST_1_LABELS=gpu=true,arch=amd64

# Host 2 example (build server):
# CONTAINERS_REMOTE_HOST_2_NAME=build-server-1
# CONTAINERS_REMOTE_HOST_2_ADDRESS=192.168.1.101
# CONTAINERS_REMOTE_HOST_2_PORT=22
# CONTAINERS_REMOTE_HOST_2_USER=deploy
# CONTAINERS_REMOTE_HOST_2_KEY=~/.ssh/build_key
# CONTAINERS_REMOTE_HOST_2_RUNTIME=podman
# CONTAINERS_REMOTE_HOST_2_LABELS=build=true,arch=arm64

# Host 3 example (storage node):
# CONTAINERS_REMOTE_HOST_3_NAME=storage-node-1
# CONTAINERS_REMOTE_HOST_3_ADDRESS=10.0.0.50
# CONTAINERS_REMOTE_HOST_3_PORT=2222
# CONTAINERS_REMOTE_HOST_3_USER=admin
# CONTAINERS_REMOTE_HOST_3_KEY=~/.ssh/storage_key
# CONTAINERS_REMOTE_HOST_3_RUNTIME=docker
# CONTAINERS_REMOTE_HOST_3_LABELS=storage=true,ssd=true
